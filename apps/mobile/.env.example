# VITAL mobile environment
EXPO_PUBLIC_API_URL=http://192.168.1.10:3000/api/v1
EXPO_PUBLIC_SUPABASE_URL=https://[project].supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Google Maps JS API key for the in-app location picker (WebView).
# Without it, the booking screen falls back to a manual address field.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
