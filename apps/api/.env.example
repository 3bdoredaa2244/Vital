# VITAL API environment
NODE_ENV=development
PORT=3000

# Supabase Postgres connection string — use the TRANSACTION POOLER (port 6543).
# Format: postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?sslmode=require
# URL-encode any special characters in the password. The API client uses prepare:false for this pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

