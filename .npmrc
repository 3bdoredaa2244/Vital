# React Native's Metro bundler cannot resolve pnpm's default isolated
# (symlinked, nested) node_modules layout. Expo's monorepo guide requires a
# flat layout, so we use the hoisted linker. Without this, Metro fails with
# "Unable to resolve module" for transitive deps such as
# react-native-css-interop/jsx-runtime and @expo/metro-runtime.
node-linker=hoisted
